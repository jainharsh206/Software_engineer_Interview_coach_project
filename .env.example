# Google AI Studio / Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key-here

# Optional — if unset, the app tries gemini-2.5-flash-lite then gemini-2.5-flash.
# If you still get 429 (limit:0), enable billing or pick a model from AI Studio.
# GEMINI_MODEL=gemini-2.5-flash-lite
